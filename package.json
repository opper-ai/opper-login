{
    "name": "@opperai/login",
    "version": "0.3.0",
    "description": "Login with Opper - OAuth SDK for AI inference",
    "type": "module",
    "tshy": {
        "exports": {
            ".": "./src/index.ts",
            "./react": "./src/react.tsx",
            "./package.json": "./package.json"
        }
    },
    "sideEffects": [
        "./dist/styles.css"
    ],
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tshy && node scripts/post-build.mjs",
        "dev": "tshy --watch",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/opper-ai/opper-login"
    },
    "author": "Opper AI",
    "license": "MIT",
    "peerDependencies": {
        "react": ">=18"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "tshy": "^3.0.0",
        "typescript": "^5.8.0"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.ts",
                "default": "./dist/esm/index.js"
            },
            "require": {
                "types": "./dist/commonjs/index.d.ts",
                "default": "./dist/commonjs/index.js"
            }
        },
        "./react": {
            "import": {
                "types": "./dist/esm/react.d.ts",
                "default": "./dist/esm/react.js"
            },
            "require": {
                "types": "./dist/commonjs/react.d.ts",
                "default": "./dist/commonjs/react.js"
            }
        },
        "./package.json": "./package.json",
        "./styles.css": "./dist/styles.css"
    },
    "main": "./dist/commonjs/index.js",
    "types": "./dist/commonjs/index.d.ts",
    "module": "./dist/esm/index.js"
}
